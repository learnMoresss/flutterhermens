# 复制为 gateway/.env 或服务器 ~/gateway/.env（勿提交含真实密码的文件）
#
# 宿主机 ~/.hermes/.env 还须启用 Hermes API Server。
# docker-compose 须挂载 HERMES_HOME、备份目录、上传目录（见 gateway/docker-compose.yml）。

JWT_SECRET=请改为足够长的随机串

# Hermes API Server（Docker 容器内访问宿主机常用 172.18.0.1）
HERMES_API_ORIGIN=http://172.18.0.1:8642
HERMES_DASHBOARD_ORIGIN=http://172.18.0.1:9119
HERMES_API_SERVER_KEY=与宿主机 API_SERVER_KEY 一致
HERMES_DASHBOARD_TOKEN=hermes dashboard 启动日志中的 session token

# App 登录（Gateway 签发 JWT，不向 App 暴露 Hermes Key）
GATEWAY_AUTH_USER=your_username
GATEWAY_AUTH_PASSWORD=请填写 App 登录密码

HERMES_BACKUP_SOURCE=/data/hermes
HERMES_BACKUP_DIR=/data/hermes-backups
HERMES_BACKUP_MAX=7
HERMES_DAILY_BACKUP_HOUR=2

# Agent 管理 / 记忆 / Provider
HERMES_HOME=/home/ubuntu/.hermes

# 公网媒体/项目（App 预览、Markdown 图片、应用 Tab）
# GATEWAY_PUBLIC_BASE_URL=https://your-gateway.example.com
# GATEWAY_PROJECTS_ROOT=/data/hermes-projects
# GATEWAY_UPLOAD_DIR=/data/gateway-uploads
# GATEWAY_MEDIA_ROOTS=/tmp,/home/ubuntu/.hermes,/data/gateway-uploads,/data/hermes-projects
