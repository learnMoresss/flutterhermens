<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ 系统 SplashScreen：纯黑底，不展示 ic_launcher 白圈 -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_empty_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/black</item>
    </style>
</resources>
