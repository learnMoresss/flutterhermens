NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# 可选：网关读写的 .env 绝对路径
# GATEWAY_ENV_FILE=/opt/hermes/gateway/.env

JWT_SECRET=change-this-to-a-long-random-string

# Hermes API Server（OpenAI 兼容，默认 :8642）
# 简写：auto / docker-host / docker-bridge / 裸 IPv4 / host:port
HERMES_API_ORIGIN=http://172.18.0.1:8642
HERMES_API_SERVER_KEY=与宿主机 ~/.hermes/.env 中 API_SERVER_KEY 一致

# Hermes Dashboard REST（可选，会话列表/历史，默认 :9119）
HERMES_DASHBOARD_ORIGIN=http://172.18.0.1:9119
HERMES_DASHBOARD_TOKEN=hermes dashboard 启动日志中的 session token

# App 登录（Gateway 本地校验并签发 JWT）
GATEWAY_AUTH_USER=syl
GATEWAY_AUTH_PASSWORD=change-me

# 备份：待打包目录与存放目录（绝对路径；Docker 下请用 volume 挂载进容器）
HERMES_BACKUP_SOURCE=/data/hermes
HERMES_BACKUP_DIR=/data/hermes-backups
HERMES_BACKUP_MAX=7
HERMES_DAILY_BACKUP_HOUR=2

# 可选：一行 shell，由网关执行以实现 Hermes 进程/容器重启
# HERMES_RESTART_SHELL=cd /opt/hermes && docker compose restart

# 可选：维护脚本（App 中「执行维护」调用 POST /v1/admin/hermes/run preset=maintenance）
# HERMES_MAINTENANCE_SHELL=/opt/hermes/scripts/maintenance.sh

# Phase 5：Agent 配置目录（models.json、config.yaml、memories/ 等）
# HERMES_HOME=/home/ubuntu/.hermes
# HERMES_PYTHON=/home/ubuntu/.hermes/hermes-agent/venv/bin/python3
# HERMES_REPO=/home/ubuntu/.hermes/hermes-agent

# Phase 4/5：上传持久化
# GATEWAY_UPLOAD_DIR=/data/gateway-uploads

# 公网媒体/文件暴露
# GATEWAY_PUBLIC_BASE_URL=http://119.45.30.73:3000
# GATEWAY_MEDIA_ROOTS=/tmp,/home/ubuntu/.hermes,/data/gateway-uploads
# GATEWAY_MEDIA_TOKEN_TTL_SEC=604800

# Phase 5G：备份导入（POST /v1/admin/hermes/import，{{path}} 为服务器上归档路径）
# HERMES_IMPORT_SHELL=tar xzf {{path}} -C /tmp/hermes-import && rsync -a /tmp/hermes-import/ /home/ubuntu/.hermes/

# Phase 5D：消息网关进程管理
# HERMES_GATEWAY_STATUS_SHELL=...
# HERMES_GATEWAY_START_SHELL=...
# HERMES_GATEWAY_STOP_SHELL=...

# Phase 5A：WebSocket 透传（可选；App 默认 HTTP SSE）
# HERMES_WS_ORIGIN=ws://172.18.0.1:8642/ws

GATEWAY_VERSION=0.1.0
